{
  "info": {
    "name": "VitalPulse Blood Bank API",
    "description": "Complete API collection for the VitalPulse Blood Bank Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@vitalpulse.com\",\n  \"password\": \"admin123456\",\n  \"role\": \"admin\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        },
        {
          "name": "Register (Donor)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Donor\",\n  \"email\": \"donor@example.com\",\n  \"password\": \"donor123456\",\n  \"role\": \"donor\",\n  \"bloodGroup\": \"O+\",\n  \"phone\": \"+1987654321\"\n}"
            }
          }
        },
        {
          "name": "Register (Hospital)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"St. Jude Hospital\",\n  \"email\": \"hospital@stjude.com\",\n  \"password\": \"hospital123\",\n  \"role\": \"hospital\",\n  \"organizationName\": \"St. Jude General Hospital\",\n  \"phone\": \"+1122334455\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vitalpulse.com\",\n  \"password\": \"admin123456\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get All Inventory",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/inventory?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Add Blood Units",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/inventory",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O-\",\n  \"units\": 42,\n  \"capacity\": 500,\n  \"source\": \"Donor Portal\"\n}"
            }
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/inventory/availability/O-",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Donations",
      "item": [
        {
          "name": "Get All Donations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/donations",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Donation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/donations",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O+\",\n  \"units\": 1,\n  \"volume\": 450,\n  \"donationType\": \"Whole Blood\",\n  \"notes\": \"Regular donation\"\n}"
            }
          }
        },
        {
          "name": "Get My Donations (Donor)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/donations/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Get All Requests",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/requests",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Blood Request (Hospital)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/requests",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O-\",\n  \"units\": 5,\n  \"priority\": \"Emergency\",\n  \"reason\": \"Trauma surgery\",\n  \"patientName\": \"John Smith\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?search=john&role=donor",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
